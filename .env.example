# Cactus backend persistence
# Leave these blank for the local JSON fallback.
# Set both on the server only to use Supabase/Postgres.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: lets `npm run supabase:a1` link and push migrations via Supabase CLI.
# If omitted, apply supabase/migrations/0001_cactus_foundation.sql manually in the SQL editor.
CACTUS_SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Optional local fallback path
CACTUS_BACKEND_STATE_PATH=/tmp/cactus-vault-prototype/backend-state.json
